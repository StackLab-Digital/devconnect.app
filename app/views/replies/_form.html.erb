<%# Formulário de Nova Resposta ou Edição %>
<%# Usa form_id passado como local ou fallback para :new_reply %>
<%= form_with(model: [@discussion, reply], id: (local_assigns[:form_id] || dom_id(@discussion, :new_reply) || dom_id(@discussion, :edit_reply)), class: "reply-form mt-6") do |form| %>
  <% if reply.errors.any? %>
    <div id="error_explanation" class="mb-4 bg-red-50 text-red-700 border border-red-200 px-4 py-3 rounded-md dark:bg-red-800/10 dark:border-red-900 dark:text-red-400" role="alert">
      <h2 class="font-semibold text-sm mb-1"><%= pluralize(reply.errors.count, "erro") %> impediu esta resposta de ser salva:</h2>
      <ul class="list-disc list-inside text-sm">
        <% reply.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Campo de Conteúdo (Rich Text) %>
  <div>
    <%# Esconder label visualmente, mas manter para acessibilidade %>
    <%= form.label :content, "Escreva sua resposta", class: "sr-only" %> 
    <div class="mt-1 block w-full rounded-md border border-gray-300 shadow-sm dark:bg-neutral-800 dark:border-neutral-700 focus-within:border-lime-500 focus-within:ring-1 focus-within:ring-lime-500 dark:focus-within:border-lime-500">
       <%= form.rich_text_area :content, 
            placeholder: "Compartilhe sua resposta...", 
            class: "block w-full border-0 focus:ring-0 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-800 dark:text-neutral-300 min-h-[150px] p-3" %>
    </div>
  </div>

  <%# Botão de Envio - Texto condicional %>
  <div class="mt-4 flex justify-end mb-8">
    <%= form.submit (reply.persisted? ? "Atualizar Resposta" : "Publicar Resposta"), 
                    class: "py-2 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-lime-500 text-white hover:bg-lime-600 disabled:opacity-50 disabled:pointer-events-none" %>
  </div>
<% end %>
