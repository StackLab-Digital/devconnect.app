<% content_for :title, "Editar Resposta" %>

<div class="max-w-[85rem] px-4 pb-10 sm:px-6 lg:px-8 lg:pb-14 mx-auto mt-8">
  <%# Header com título e botões %>
  <div class="flex items-center justify-between mb-6">
    <h1 class="font-bold text-3xl">Editar Resposta</h1>
    <div class="flex gap-x-2">
      <%# Botão Cancelar %>
      <%= link_to "Cancelar", discussion_path(@discussion, anchor: dom_id(@reply)), class: "py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-900 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-800" %>
      <%# Botão Atualizar associado ao form pelo ID %>
      <%= button_tag "Atualizar Resposta", type: :submit, form: dom_id(@reply, :edit), class: "py-2 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-lime-600 text-white hover:bg-lime-700 disabled:opacity-50 disabled:pointer-events-none focus:outline-none focus:ring-2 focus:ring-lime-500 focus:ring-offset-2 dark:focus:ring-offset-neutral-900 transition-all" %>
    </div>
  </div>

  <%# Debug Temporário %>
  <p class="my-4 p-3 bg-yellow-100 text-yellow-800 rounded border border-yellow-300">
    DEBUG: Reply ID: <%= @reply.id %>, Content Body Present?: <%= @reply.content.body.present? %>
    <br>
    Content Object: <%= @reply.content.inspect %>
  </p>
  <%# Fim Debug %>

  <%# Renderiza o formulário, passando discussion e reply, e um ID específico para edição %>
  <%# Nota: O partial _form precisa ser ajustado para aceitar/usar um form_id local ou ter IDs condicionais %>
  <%= render "form", discussion: @discussion, reply: @reply, form_id: dom_id(@reply, :edit) %>

</div>
