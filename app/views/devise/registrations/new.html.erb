<div class="max-w-md mx-auto w-full">
  <div class="bg-white rounded-xl shadow dark:bg-neutral-900">
    <div class="p-6 sm:p-8">
      <h2 class="text-2xl font-bold text-center text-gray-800 dark:text-white mb-6">Criar nova conta</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :name, "Nome Completo", class: "block text-sm font-medium mb-1 text-gray-700 dark:text-neutral-300" %>
          <%= f.text_field :name, autocomplete: "name", class: "py-2 px-3 block w-full border-gray-300 rounded-md shadow-sm text-sm focus:border-lime-500 focus:ring-lime-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-300 dark:focus:ring-neutral-600", placeholder: "Seu nome" %>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-medium mb-1 text-gray-700 dark:text-neutral-300" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "py-2 px-3 block w-full border-gray-300 rounded-md shadow-sm text-sm focus:border-lime-500 focus:ring-lime-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-300 dark:focus:ring-neutral-600", placeholder: "seu@email.com" %>
  </div>

        <div>
          <%= f.label :password, "Senha", class: "block text-sm font-medium mb-1 text-gray-700 dark:text-neutral-300" %>
    <% if @minimum_password_length %>
            <em class="text-xs text-gray-500 dark:text-neutral-400">(mínimo de <%= @minimum_password_length %> caracteres)</em>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "py-2 px-3 block w-full border-gray-300 rounded-md shadow-sm text-sm focus:border-lime-500 focus:ring-lime-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-300 dark:focus:ring-neutral-600", placeholder: "Crie uma senha" %>
  </div>

        <div>
          <%= f.label :password_confirmation, "Confirmação da Senha", class: "block text-sm font-medium mb-1 text-gray-700 dark:text-neutral-300" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "py-2 px-3 block w-full border-gray-300 rounded-md shadow-sm text-sm focus:border-lime-500 focus:ring-lime-500 disabled:opacity-50 disabled:pointer-events-none dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-300 dark:focus:ring-neutral-600", placeholder: "Repita a senha" %>
  </div>

        <div>
          <%= f.submit "Criar Conta", class: "w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-lime-500 text-white hover:bg-lime-600 disabled:opacity-50 disabled:pointer-events-none focus:outline-none focus:ring-2 focus:ring-lime-500 focus:ring-offset-2 dark:focus:ring-offset-neutral-900 transition-all" %>
  </div>
<% end %>

      <div class="text-center mt-6">
<%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
