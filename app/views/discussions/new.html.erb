<% content_for :title, "New discussion" %>

<div class="max-w-[85rem] px-4 pb-10 sm:px-6 lg:px-8 lg:pb-14 mx-auto mt-8">
  <div>
    <%# Wrapper para título e botão %>
    <div class="flex items-center justify-between mb-4">
      <h1 class="font-bold text-4xl">Nova Discussão</h1>
      <%# Botão movido para cá, associado ao form pelo ID %>
      <%= button_tag "Criar Discussão", type: :submit, form: "new_discussion_form", class: "py-2 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-lime-600 text-white hover:bg-lime-700 disabled:opacity-50 disabled:pointer-events-none focus:outline-none focus:ring-2 focus:ring-lime-500 focus:ring-offset-2 dark:focus:ring-offset-neutral-900 transition-all" %>
    </div>

    <%# Adiciona ID ao form para associação com o botão %>
    <%= render "form", discussion: @discussion, form_id: "new_discussion_form" %>

    <%# Removido o botão Voltar %>
  </div>
</div>
